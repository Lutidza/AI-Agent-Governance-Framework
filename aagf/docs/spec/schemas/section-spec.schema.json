{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aagf.dev/schemas/section-spec.schema.json",
  "title": "AAGF section specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "section",
    "version",
    "entries"
  ],
  "properties": {
    "section": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "ifThen": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "if",
        "then"
      ],
      "properties": {
        "if": {
          "type": "string",
          "minLength": 1
        },
        "then": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "objective",
        "template"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z0-9-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "template": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "file_slug",
        "title",
        "intent",
        "rules",
        "if_then",
        "checks"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z0-9-]+$"
        },
        "file_slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "if_then": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ifThen"
          }
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "handoff": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prompts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/prompt"
          }
        }
      }
    }
  }
}
