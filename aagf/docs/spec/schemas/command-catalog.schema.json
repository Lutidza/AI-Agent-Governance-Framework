{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aagf.dev/schemas/command-catalog.schema.json",
  "title": "AAGF command catalog specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "catalog_id",
    "defaults",
    "commands"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "catalog_id": {
      "type": "string",
      "pattern": "^[A-Z0-9-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "defaults": {
      "$ref": "#/$defs/defaults"
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/command"
      }
    }
  },
  "$defs": {
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "output_format",
        "confirm_fix"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "review",
            "fix"
          ]
        },
        "output_format": {
          "type": "string",
          "minLength": 1
        },
        "confirm_fix": {
          "type": "boolean"
        }
      }
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "required",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "type": {
          "type": "string",
          "enum": [
            "path",
            "rule_id",
            "profile_id",
            "mode",
            "string",
            "boolean"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "safetyGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confirm_required",
        "details"
      ],
      "properties": {
        "confirm_required": {
          "type": "boolean"
        },
        "details": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "fields"
      ],
      "properties": {
        "format": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          }
        }
      }
    },
    "example": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt",
        "result"
      ],
      "properties": {
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "syntax",
        "intent",
        "scope",
        "mode",
        "params",
        "safety_gate",
        "output",
        "examples"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z0-9-]+$"
        },
        "syntax": {
          "type": "string",
          "minLength": 1
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "enum": [
            "file",
            "rule",
            "docs",
            "project"
          ]
        },
        "mode": {
          "type": "string",
          "enum": [
            "review",
            "fix",
            "mixed"
          ]
        },
        "params": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameter"
          }
        },
        "safety_gate": {
          "$ref": "#/$defs/safetyGate"
        },
        "output": {
          "$ref": "#/$defs/output"
        },
        "examples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/example"
          }
        }
      }
    }
  }
}
