{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aagf.dev/schemas/rules-index.schema.json",
  "title": "AAGF rules index specification (modular section)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "section",
    "mode",
    "version",
    "entries"
  ],
  "properties": {
    "section": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "mode": {
      "type": "string",
      "const": "modular"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/indexEntry"
      }
    }
  },
  "$defs": {
    "indexEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^AAGF-[A-Z0-9-]+$"
        },
        "source": {
          "type": "string",
          "minLength": 1,
          "pattern": "^docs/spec/.+\\.ya?ml$"
        }
      }
    }
  }
}
